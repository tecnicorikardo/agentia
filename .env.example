# Groq (gratuito - llama-3.3-70b)
GROQ_API_KEY=sua_chave_groq_aqui

# Firebase — projeto bloquinhodigital (único projeto, tudo aqui)
# Credenciais do service account do bloquinhodigital
FIREBASE_PROJECT_ID=bloquinhodigital
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@bloquinhodigital.iam.gserviceaccount.com

# Bloquinho Digital — UID do dono da loja (= ID da loja)
# Encontre rodando: node buscar_store.js seu@email.com
BLOQUINHO_OWNER_UID=seu_uid_aqui

# Evolution API v2 (WhatsApp)
# Em produção no Railway, use a URL interna: http://evolution-api.railway.internal:8080
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE=nome_da_instancia

# Servidor
PORT=3000
