# Groq (gratuito - llama-3.3-70b)
GROQ_API_KEY=sua_chave_groq_aqui

# Firebase — credenciais da conta de serviço
FIREBASE_PROJECT_ID=seu_projeto
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu_projeto.iam.gserviceaccount.com

# Evolution API v2 (WhatsApp)
# Em produção no Railway, use a URL interna: http://evolution-api.railway.internal:8080
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE=nome_da_instancia

# Servidor
PORT=3000